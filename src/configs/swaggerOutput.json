		"/auth/register": {
			"post": {
				"tags": ["Authentication"],
				"summary": "Đăng ký tài khoản mới",
				"description": "Tạo tài khoản mới và gửi email xác thực",
				"parameters": [
					{
						"name": "body",
						"in": "body",
						"required": true,
						"schema": {
							"type": "object",
							"required": ["email", "password", "fullName"],
							"properties": {
								"email": {
									"type": "string",
									"format": "email",
									"example": "user@example.com"
								},
								"password": {
									"type": "string",
									"minLength": 6,
									"example": "123456"
								},
								"fullName": {
									"type": "string",
									"example": "Nguyễn Văn A"
								}
							}
						}
					}
				],
				"responses": {
					"201": {
						"description": "Đăng ký thành công",
						"schema": {
							"type": "object",
							"properties": {
								"status": {
									"type": "boolean",
									"example": true
								},
								"message": {
									"type": "string",
									"example": "Tài khoản được tạo thành công. Vui lòng kiểm tra email để xác thực tài khoản."
								},
								"data": {
									"type": "object",
									"properties": {
										"email": {
											"type": "string",
											"example": "user@example.com"
										},
										"fullName": {
											"type": "string",
											"example": "Nguyễn Văn A"
										},
										"status": {
											"type": "string",
											"example": "pending"
										}
									}
								},
								"statusCode": {
									"type": "number",
									"example": 201
								}
							}
						}
					},
					"400": {
						"description": "Lỗi dữ liệu",
						"schema": {
							"type": "object",
							"properties": {
								"status": {
									"type": "boolean",
									"example": false
								},
								"message": {
									"type": "string",
									"example": "Email đã tồn tại trong hệ thống"
								},
								"statusCode": {
									"type": "number",
									"example": 400
								}
							}
						}
					}
				}
			}
		},
		"/auth/login": {
			"post": {
				"tags": ["Authentication"],
				"summary": "Đăng nhập",
				"description": "Đăng nhập vào hệ thống",
				"parameters": [
					{
						"name": "body",
						"in": "body",
						"required": true,
						"schema": {
							"type": "object",
							"required": ["email", "password"],
							"properties": {
								"email": {
									"type": "string",
									"format": "email",
									"example": "user@example.com"
								},
								"password": {
									"type": "string",
									"example": "123456"
								}
							}
						}
					}
				],
				"responses": {
					"200": {
						"description": "Đăng nhập thành công",
						"schema": {
							"type": "object",
							"properties": {
								"status": {
									"type": "boolean",
									"example": true
								},
								"message": {
									"type": "string",
									"example": "Đăng nhập thành công"
								},
								"data": {
									"type": "object",
									"properties": {
										"account": {
											"type": "object",
											"properties": {
												"_id": {
													"type": "string",
													"example": "65f2e8b7c261e6001234abcd"
												},
												"email": {
													"type": "string",
													"example": "user@example.com"
												},
												"fullName": {
													"type": "string",
													"example": "Nguyễn Văn A"
												},
												"status": {
													"type": "string",
													"example": "active"
												}
											}
										},
										"accessToken": {
											"type": "string",
											"example": "eyJhbGciOiJIUzI1NiIs..."
										}
									}
								},
								"statusCode": {
									"type": "number",
									"example": 200
								}
							}
						}
					},
					"400": {
						"description": "Lỗi đăng nhập",
						"schema": {
							"type": "object",
							"properties": {
								"status": {
									"type": "boolean",
									"example": false
								},
								"message": {
									"type": "string",
									"example": "Email hoặc mật khẩu không đúng"
								},
								"statusCode": {
									"type": "number",
									"example": 400
								}
							}
						}
					}
				}
			}
		},
